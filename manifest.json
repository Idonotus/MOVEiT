{

  "description": "Turns all chess.com pieces into goobers",
  "manifest_version": 3,
  "name": "MOVEiT",
  "version": "1.2",
  "homepage_url": "https://github.com/Idonotus/MOVEiT",
  "icons": {
    "128": "icons/icon-128.png",
    "512": "icons/icon-512.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "MOVEiT@makit.wtf",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "web_accessible_resources": [{
    "resources": ["pieces/*.png"],
    "matches": ["*://*/*"]
  }],
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["*://*.chess.com/*"],
      "js": ["MOVEiT-chess.js"]
    },
    {
      "matches": ["*://*.lichess.org/*"],
      "js": ["MOVEiT-lichess.js"]
    }
  ]

}
